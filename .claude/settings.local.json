{
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npx supabase:*)",
      "Bash(cat:*)",
      "mcp__supabase__list_tables",
      "mcp__supabase__execute_sql",
      "Bash(node -e:*)",
      "mcp__supabase__get_edge_function",
      "Bash(supabase projects:*)",
      "mcp__supabase__deploy_edge_function",
      "mcp__supabase__get_logs",
      "Bash(curl:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(rm:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm install:*)",
      "Bash(for file in Card.tsx ChipGroup.tsx ConfirmDialog.tsx Input.tsx LoadingSpinner.tsx Modal.tsx StatusBadge.tsx Tabs.tsx Textarea.tsx Toast.tsx)",
      "Bash(do sed -i \"s/from ''cva''/from ''class-variance-authority''/g\" \"$file\")",
      "Bash(done)",
      "Bash(npm run build:*)",
      "Bash(find:*)",
      "Bash(npx tsc:*)",
      "mcp__supabase__apply_migration",
      "Bash(dir /s \"c:\\Users\\david\\OneDrive\\Escritorio\\app\\supabase\\functions\")",
      "Bash(npx shadcn@latest add:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "WebFetch(domain:www.mercadopago.com.co)",
      "WebFetch(domain:www.mercadopago.com.ar)",
      "WebFetch(domain:github.com)",
      "mcp__TestSprite__testsprite_bootstrap",
      "mcp__TestSprite__testsprite_generate_code_summary"
    ],
    "additionalDirectories": [
      "C:\\Users\\david\\OneDrive\\Escritorio\\app\\testsprite_tests\\tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-scan.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/push-reminder.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/console-log-check.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/format-file.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck.sh",
            "timeout": 60000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/compact-save.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase",
    "mercadopago"
  ]
}
